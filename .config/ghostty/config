# By default Reload config with ctrl + shift + ,
config-file = themes/tokyonight
background-opacity = 0.88

# Note: In Wayland, background blur requires support from the compositor.
background-blur-radius = 25

font-family = JetBrainsMonoNL Nerd Font
font-size = 13
font-feature = -liga,-calt,-dlig
cursor-style = block
cursor-style-blink = false
cursor-color = cell-foreground
cursor-text = cell-background
unfocused-split-opacity = 0.55
split-divider-color = #524f67

# Let the tiling window manager handle borders and titlebars natively
window-decoration = false
window-padding-x = 10
window-padding-y = 10
window-padding-balance = true

mouse-hide-while-typing = true
confirm-close-surface = false

# extras
shell-integration-features = no-cursor
copy-on-select = clipboard

# Custom Keybinds & Config
keybind = ctrl+bracket_left=text:\x1b
# Mapped away from 'super' (Mod4) to prevent WM conflicts
keybind = ctrl+shift+i=inspector:toggle
keybind = ctrl+space>[=reload_config

#-------------------------------------------

# Tmux-style multiplexing via leader key (ctrl+space)
# Note: Because your window manager inherently tiles and tabs windows, 
# you may find these internal Ghostty splits redundant in daily use.
keybind = ctrl+space>c=new_tab
keybind = ctrl+space>n=new_window
keybind = ctrl+space>x=close_surface

# tab nav
keybind = ctrl+space>1=goto_tab:1
keybind = ctrl+space>2=goto_tab:2
keybind = ctrl+space>3=goto_tab:3
keybind = ctrl+space>4=goto_tab:4
keybind = ctrl+space>5=goto_tab:5
keybind = ctrl+space>6=goto_tab:6
keybind = ctrl+space>7=goto_tab:7
keybind = ctrl+space>8=goto_tab:8
keybind = ctrl+space>9=goto_tab:9

# splitting
keybind = ctrl+space>\=new_split:right
keybind = ctrl+space>-=new_split:down
keybind = ctrl+space>e=equalize_splits

# split nav 
keybind = ctrl+space>h=goto_split:left
keybind = ctrl+space>j=goto_split:bottom
keybind = ctrl+space>k=goto_split:top
keybind = ctrl+space>l=goto_split:right

# Shaders
# custom-shader = shaders/bettercrt.glsl
# custom-shader = shaders/retro-terminal.glsl